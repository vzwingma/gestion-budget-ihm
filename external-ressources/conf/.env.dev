# Version
VITE_BUDGET_VERSION=DEV.22

VITE_CONFIG_DEBUG=true

# Accès aux services
VITE_CONFIG_URL_COMPTES=http://localhost:3021
VITE_CONFIG_URL_OPERATIONS=http://localhost:3020
VITE_CONFIG_URL_PARAMS=http://localhost:3022
